{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ranbits.com/data/6g-tracker.schema.json",
  "title": "ranbits 6G tracker",
  "description": "Canonical, source-of-truth data for the ranbits.com 6G standardization tracker. Every requirement/candidate fact carries a source_url and source_date. The fetch/render scripts validate against this schema and never publish an unsourced value as fact.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "releases", "items", "domains", "changelog"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated", "disclaimer"],
      "properties": {
        "generated": { "type": "string", "description": "ISO date the file was last generated/edited (YYYY-MM-DD)." },
        "disclaimer": { "type": "string" },
        "baseline_note": { "type": "string" },
        "schema_version": { "type": "string" }
      }
    },
    "releases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "status", "source_url", "source_date"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "enum": ["complete", "in_progress", "planned"] },
          "summary": { "type": "string" },
          "tracks": { "type": "array", "items": { "type": "string" } },
          "milestones": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "date", "status"],
              "properties": {
                "label": { "type": "string" },
                "date": { "type": "string", "description": "YYYY-MM or YYYY-MM-DD; may be prefixed with ~ to mark an expected/estimated date." },
                "status": { "enum": ["complete", "in_progress", "planned", "expected"] },
                "classification": { "enum": ["requirement", "candidate", "foundation"] },
                "source_url": { "type": "string" },
                "source_date": { "type": "string" }
              }
            }
          },
          "source_url": { "type": "string" },
          "source_date": { "type": "string" },
          "source_tier": { "enum": ["primary", "secondary"] }
        }
      }
    },
    "items": {
      "type": "array",
      "description": "Study items, work items, TRs and TSs being tracked.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "type", "classification", "domains", "status", "source_url", "source_date", "source_tier"],
        "properties": {
          "id": { "type": "string", "description": "Stable key, usually the document or plenary ID, e.g. 'TR 22.870'." },
          "doc_id": { "type": "string" },
          "title": { "type": "string" },
          "type": { "enum": ["study_item", "work_item", "tr", "ts", "recommendation", "agreement", "spectrum"] },
          "classification": { "enum": ["requirement", "candidate", "foundation"] },
          "working_groups": { "type": "array", "items": { "type": "string" } },
          "release": { "type": "string" },
          "domains": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "completion": {
            "type": ["integer", "null"],
            "minimum": 0,
            "maximum": 100,
            "description": "Percent complete. MUST be null unless an authoritative source states a figure — never guessed."
          },
          "status": { "enum": ["approved", "in_progress", "planned", "agreed", "draft", "study"] },
          "status_label": { "type": "string" },
          "notes": { "type": "string" },
          "source_url": { "type": "string" },
          "source_date": { "type": "string" },
          "source_tier": { "enum": ["primary", "secondary"] }
        }
      }
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "page", "items"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "short": { "type": "string" },
          "page": { "type": "string" },
          "summary": { "type": "string" },
          "items": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "changelog": {
      "type": "array",
      "description": "Append-only. Each entry records what changed and the source it came from.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "type", "summary"],
        "properties": {
          "date": { "type": "string" },
          "type": { "enum": ["init", "add", "update", "status", "note", "skip"] },
          "summary": { "type": "string" },
          "items": { "type": "array", "items": { "type": "string" } },
          "field": { "type": "string" },
          "from": { "type": ["string", "integer", "null"] },
          "to": { "type": ["string", "integer", "null"] },
          "source_url": { "type": "string" },
          "source_date": { "type": "string" },
          "source_tier": { "enum": ["primary", "secondary", "manual"] }
        }
      }
    }
  }
}
